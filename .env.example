# Copy to .env and set your key from https://openrouter.ai/
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# If port 8001 is already in use, pick another (e.g. 8002) and restart.
# Frontend API URL defaults to http://localhost:$BACKEND_PORT via vite.config.js.
BACKEND_PORT=8001

# Optional explicit API origin (overrides BACKEND_PORT-based default):
# VITE_API_BASE=http://localhost:8002

# Optional Interrogator Stage 0 settings (first message only):
# INTERROGATOR_MODEL=google/gemini-2.5-flash
# INTERROGATOR_MIN_QUESTIONS=2
# INTERROGATOR_MAX_QUESTIONS=5

# Profile guardrails:
# DEFAULT_PROFILE_ID=marketing
# GUARDRAIL_ENFORCEMENT_MODE=degraded  # off | degraded | strict_fail
# GUARDRAIL_ROLE_SCHEMA_MIN_RATIO=1.0
# GUARDRAIL_RUBRIC_COVERAGE_MIN_RATIO=1.0
# GUARDRAIL_MAX_RECOMMENDATION_OVERLAP=0.80
# GUARDRAIL_MIN_UNIQUE_RISK_COUNT=1
